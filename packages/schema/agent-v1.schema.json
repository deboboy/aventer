{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aventer.dev/schemas/agent-v1.json",
  "title": "AgentEventV1",
  "type": "object",
  "required": [
    "spec_version",
    "id",
    "type",
    "timestamp",
    "run_id",
    "agent_id",
    "org_id",
    "data"
  ],
  "properties": {
    "spec_version": { "const": "agent-v1" },
    "id": { "type": "string", "pattern": "^evt_[a-zA-Z0-9_-]+$" },
    "type": {
      "type": "string",
      "enum": [
        "task.started",
        "task.completed",
        "task.failed",
        "tool.called",
        "tool.failed",
        "agent.started",
        "agent.stopped",
        "llm.error"
      ]
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "org_id": { "type": "string", "minLength": 1 },
    "data": { "type": "object", "additionalProperties": true },
    "context": {
      "type": "object",
      "properties": {
        "parent_id": { "type": "string" },
        "step": { "type": "integer", "minimum": 0 },
        "framework": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
