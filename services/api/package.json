{
  "name": "@aventer/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --env-file=../../.env.local ./node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "start": "node dist/index.js",
    "db:migrate": "node dist/migrate.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aventer/delivery": "0.0.1",
    "@aventer/schema": "0.0.1",
    "@hono/node-server": "^1.14.1",
    "bcryptjs": "^3.0.3",
    "hono": "^4.7.10",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.15.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
